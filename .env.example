# =============================================================================
# ENVIRONMENT VARIABLES - Coinbase Marketplace
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# SECURITY NOTES:
# - Variables with NEXT_PUBLIC_ prefix are exposed to the browser (public)
# - Variables WITHOUT NEXT_PUBLIC_ prefix are server-only (private/secure)
# - NEVER put API keys, secrets, or credentials in NEXT_PUBLIC_ variables
# =============================================================================

# -----------------------------------------------------------------------------
# PUBLIC VARIABLES (safe to expose - visible in browser)
# -----------------------------------------------------------------------------

# Base App Download URLs
NEXT_PUBLIC_BASE_APP_URL=https://www.coinbase.com/wallet/downloads
NEXT_PUBLIC_BASE_APP_IOS_URL=https://apps.apple.com/us/app/base-formerly-coinbase-wallet/id1278383455
NEXT_PUBLIC_BASE_APP_ANDROID_URL=https://play.google.com/store/apps/details?id=org.toshi

# Marketplace URL (for users who already have a wallet)
NEXT_PUBLIC_MARKETPLACE_URL=/marketplace

# -----------------------------------------------------------------------------
# PRIVATE/SERVER VARIABLES (never exposed to browser)
# Add any API keys or secrets here WITHOUT the NEXT_PUBLIC_ prefix
# -----------------------------------------------------------------------------

# Example (uncomment and fill if needed):
# COINBASE_API_KEY=your-api-key-here
# COINBASE_API_SECRET=your-api-secret-here

# -----------------------------------------------------------------------------
# NGROK CONFIGURATION (for development tunneling)
# -----------------------------------------------------------------------------
# To use ngrok with basic authentication for security:
#   ngrok http 3000 --basic-auth="username:password"
#
# Replace "username:password" with your own credentials.
# This prevents unauthorized access to your development server.
